{
  "name": "amazon_shipment_ingestion_weekly",
  "email_notifications": {
    "on_failure": [
      "sia.song@example.com"
    ],
    "no_alert_for_skipped_runs": false
  },
  "webhook_notifications": {},
  "notification_settings": {
    "no_alert_for_skipped_runs": false,
    "no_alert_for_canceled_runs": false
  },
  "timeout_seconds": 0,
  "schedule": {
    "quartz_cron_expression": "9 0 6 * * ?",
    "timezone_id": "America/New_York",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "tasks": [
    {
      "task_key": "ingest_items",
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@example.com/amazon_ingestion/01_ingest_shipment_items",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 0,
      "retry_on_timeout": false,
      "timeout_seconds": 1800,
      "email_notifications": {},
      "webhook_notifications": {},
      "environment_key": "ingest_items_environment",
      "disabled": false
    },
    {
      "task_key": "ingest_shipments",
      "depends_on": [
        {
          "task_key": "ingest_items"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@example.com/amazon_ingestion/02_ingest_shipments",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 0,
      "retry_on_timeout": false,
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "environment_key": "ingest_items_environment",
      "disabled": false
    },
    {
      "task_key": "build_gold",
      "depends_on": [
        {
          "task_key": "ingest_items"
        },
        {
          "task_key": "ingest_shipments"
        }
      ],
      "run_if": "ALL_SUCCESS",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@example.com/amazon_ingestion/03_gold_receiving_by_sku",
        "source": "WORKSPACE"
      },
      "max_retries": 1,
      "min_retry_interval_millis": 0,
      "retry_on_timeout": false,
      "timeout_seconds": 0,
      "email_notifications": {},
      "webhook_notifications": {},
      "environment_key": "ingest_items_environment",
      "disabled": false
    }
  ],
  "queue": {
    "enabled": true
  },
  "environments": [
    {
      "environment_key": "ingest_items_environment",
      "spec": {
        "environment_version": "5"
      }
    }
  ],
  "performance_target": "PERFORMANCE_OPTIMIZED"
}