{
  "name": "slice_1_daily",
  "run_as": { "user_name": "sia.song@32degrees.com" },
  "max_concurrent_runs": 1,
  "queue": { "enabled": true },
  "schedule": {
    "quartz_cron_expression": "0 30 6 * * ?",
    "timezone_id": "America/New_York",
    "pause_status": "UNPAUSED"
  },
  "email_notifications": {
    "on_failure": [ "sia.song@32degrees.com" ],
    "no_alert_for_skipped_runs": false
  },
  "notification_settings": {
    "no_alert_for_skipped_runs": false,
    "no_alert_for_canceled_runs": false
  },
  "job_clusters": [
    {
      "job_cluster_key": "slice1_job_cluster",
      "new_cluster": {
        "spark_version": "17.3.x-scala2.13",
        "node_type_id": "i3.xlarge",
        "autoscale": { "min_workers": 1, "max_workers": 3 },
        "data_security_mode": "SINGLE_USER",
        "single_user_name": "sia.song@32degrees.com",
        "custom_tags": { "project": "analytics-platform", "env": "dev" }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "dim_date",
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/01_build_dim_date",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": false,
      "timeout_seconds": 1800
    },
    {
      "task_key": "dim_channel",
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/02_seed_dim_channel",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": false,
      "timeout_seconds": 1800
    },
    {
      "task_key": "dim_product",
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/03_build_dim_product",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": false,
      "timeout_seconds": 1800
    },
    {
      "task_key": "fact_orders_line",
      "depends_on": [
        { "task_key": "dim_date" },
        { "task_key": "dim_channel" },
        { "task_key": "dim_product" }
      ],
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/04_build_fact_orders_line",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 120000,
      "retry_on_timeout": false,
      "timeout_seconds": 7200
    },
    {
      "task_key": "dq_gate",
      "depends_on": [ { "task_key": "fact_orders_line" } ],
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/dq_gate",
        "base_parameters": {
          "dq_config_dir": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/dq_configs",
          "report_dir": "dbfs:/tmp/dq_reports"
        },
        "source": "WORKSPACE"
      },
      "max_retries": 0,
      "timeout_seconds": 1800
    },
    {
      "task_key": "metric_refresh",
      "depends_on": [ { "task_key": "dq_gate" } ],
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/metric_refresh_placeholder",
        "source": "WORKSPACE"
      },
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": false,
      "timeout_seconds": 600
    },
    {
      "task_key": "success_digest",
      "depends_on": [ { "task_key": "metric_refresh" } ],
      "run_if": "ALL_SUCCESS",
      "job_cluster_key": "slice1_job_cluster",
      "notebook_task": {
        "notebook_path": "/Workspace/Users/sia.song@32degrees.com/analytics-platform/slice_1/success_digest",
        "base_parameters": {
          "fact_fqn": "mvdevdatabricks.analytics_platform_32degrees.fact_orders_line",
          "history_fqn": "mvdevdatabricks.analytics_platform_32degrees.pipeline_run_history",
          "report_dir": "dbfs:/tmp/dq_reports"
        },
        "source": "WORKSPACE"
      },
      "max_retries": 1,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": false,
      "timeout_seconds": 600
    }
  ]
}
